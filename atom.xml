    <content type="html"><![CDATA[<h1><span id="624">6.24</span></h1><ul><li><input checked disabled type="checkbox"> 复习数学建模</li></ul><h1><span id="625">6.25</span></h1><ul><li><input checked disabled type="checkbox"> 数学建模考试14:00-16:00 [completion:: 2024-06-25 18:26]</li><li><input checked disabled type="checkbox"> 完善hexo [completion:: 2024-06-25 12:37]</li></ul><h1><span id="626">6.26</span></h1><ul><li><input disabled type="checkbox"> 去趟阿姨家 16:00-?</li><li><input checked disabled type="checkbox"> 历年卷一套</li><li><input disabled type="checkbox"> 数学建模回忆卷</li><li><input disabled type="checkbox"> 历年卷知识点总结</li></ul>]]></content>
    
    
      
      
    <summary type="html">&lt;h1&gt;&lt;span id=&quot;624&quot;&gt;6.24&lt;/span&gt;&lt;/h1&gt;&lt;ul&gt;
